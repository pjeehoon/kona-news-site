            text-decoration: underline;
        }
    </style>
    <script>
        function toggleVersionHistory() {
            const versionList = document.querySelector('.version-list');
            const toggleIcon = document.querySelector('.version-toggle');
            
            if (versionList.classList.contains('open')) {
                versionList.classList.remove('open');
                toggleIcon.classList.remove('open');
            } else {
                versionList.classList.add('open');
                toggleIcon.classList.add('open');
            }
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>"찌개용 앞다리살이었다"…울릉도 '비계 삼겹살' 업주 사과</h1>
            <p>
                분석 시간: 2025-07-22 15:56:00
                
            </p>
        </div>
        
        <div class="meta">
            <h3>📝 세 줄 요약</h3>
            <p>요약을 생성하는 중 오류가 발생했습니다.</p>
        </div>
        
        <div class="article-content">
<h2 style="font-size: 1.8rem; margin-bottom: 30px; color: #212529;">울릉도 식당, 삼겹살 대신 찌개용 앞다리살 제공 사실 인정…업주 사과 및 해명</h2>
<p>2025년 7월 21일, 울릉도에서 한 고깃집이 삼겹살 대신 찌개용 앞다리살을 제공하며 논란이 일고 있다. 업주는 21일 JTBC '사건반장'을 통해 공식 사과하며, 해당 고기가 찌개용 부위였다고 해명했지만, 논란은 여전히 지속되고 있다. 이번 사건은 유튜버 '꾸준 kkujun'이 공개한 영상이 계기가 되었으며, 온라인과 SNS상에서 큰 파장을 일으키고 있다.</p>
<h3>논란의 구체적 내용</h3>
<p>▶ 새로운 사실: 유튜버 '꾸준 kkujun'이 2025년 7월 19일 울릉도 여행 영상에서 해당 식당에서 제공된 삼겹살이 **절반 이상이 비계**였음을 공개하면서 논란이 시작되었다. 이후 온라인 커뮤니티와 SNS에서는 "바가지 요금"과 "비정상적인 고기 제공"에 대한 비판이 확산되었다.</p>
<p>조선일보 보도에 따르면, 해당 식당은 삼겹살로 광고했으나, 실제로는 찌개용 앞다리살을 판매하고 있었다는 의혹이 제기되었다. 특히, 영상 속에서 보여진 고기 부위는 명백히 앞다리살임이 확인되었으며, 가격은 15,000원으로 책정된 것으로 알려졌다. 이와 관련해, 일부 고객들은 "비계가 절반 이상인 고기를 먹었다"고 주장하며 불만을 표출하였다.</p>
<p>▶ 최초 공개: 업주는 21일 JTBC '사건반장' 인터뷰에서, "고기를 직원이 따로 빼놓았던 것이 아니라, 찌개용 앞다리살을 썰어줬던 것"이라며 책임을 인정하였다. 그는 "병원에 가서 직원이 고기를 빼놓았다는 이야기는 사실이 아니며, 부적절한 부위 제공에 대해 깊이 사과한다"고 해명하였다. 그러나, 일부 온라인에서는 "이 해명이 충분하지 않다"는 의견도 나오고 있으며, 업주의 책임 소재에 대한 논란은 계속되고 있다.</p>
<h3>사실 vs 의혹 구분</h3>
<p>확인된 사실은 다음과 같다. - 유튜버 '꾸준 kkujun'이 울릉도 여행 영상에서 삼겹살을 먹은 사실 - 해당 삼겹살의 절반 이상이 비계였음이 영상과 후기에서 확인됨 - 업주는 21일 공식 사과하며 찌개용 앞다리살을 제공했다고 인정</p>
<p>반면, 아직 의혹 단계인 부분은 다음과 같다. - 일부 고객들이 주장하는 "고기를 일부러 비계만 제공했다"는 의혹 - 직원이 고기를 따로 빼놓았다는 주장에 대한 구체적 증거 부족 - 업주가 주장하는 "직원이 고기를 따로 빼놓았던 것"이 사실인지 여부</p>
<h3>전문가 및 정치권 반응</h3>
<p>여야 정치권은 이번 사건에 대해 엇갈린 입장을 보이고 있다. 더불어민주당은 "관광지 식당의 위생과 신뢰성 문제를 지적하며, 엄정한 조사와 처벌이 필요하다"고 주장하는 반면, 국민의힘은 "일부 과도한 비판과 감정적 반응"을 지적하며 신중한 접근을 촉구하고 있다.</p>
<p>전문가들은 이번 사건이 소비자 보호와 식품 안전 문제를 재조명하는 계기가 될 것으로 보고 있다. 식품위생 전문가 김모 교수는 "고기 부위 표기와 위생 관리가 철저히 이루어져야 하며, 관광지에서의 신뢰성 확보가 중요하다"고 강조하였다.</p>
<p>시민사회는 이번 논란이 단순한 식품 부적절 제공을 넘어, 관광 산업 전반의 신뢰 회복을 위한 제도 개선 필요성을 제기하고 있다.</p>
<h3>향후 전망과 시사점</h3>
<p>이번 사건은 울릉도 관광지의 신뢰도에 영향을 미칠 가능성이 크다. 업계는 앞으로 부적절한 고기 제공 사례를 방지하기 위한 위생·품질 관리 강화 방안을 검토해야 하며, 정부와 지방자치단체는 관광지 식당의 위생 점검을 확대할 필요가 있다. 또한, 소비자들은 관광지 방문 시 신뢰성 있는 정보와 후기 확인이 중요하다는 점을 다시 한 번 인식하게 되었다.</p>
<p>이 사건은 관광지 식품 안전과 소비자 권익 보호의 중요성을 다시 한번 일깨우는 계기가 될 것으로 보이며, 관련 정책과 규제 강화가 예상된다.</p>
<h3>YouTube 및 추가 정보</h3>
<p>현재 관련 영상이나 추가 정보가 없습니다. 하지만, 이번 사건과 관련된 영상들은 유튜버 '꾸준 kkujun'과 JTBC '사건반장' 방송 영상에서 확인할 수 있으며, 온라인 커뮤니티에서도 다양한 후기와 분석이 이어지고 있다.</p>
<p>이와 관련된 영상은 <a href="https://www.youtube.com/channel/UCsU-I-vHLiaMfV_ceaYz5rQ" target="_blank">JTBC News</a>와 유튜브 검색을 통해 쉽게 확인 가능하다.</p>
<p>이번 논란은 관광지 내 식품 부정행위 문제에 대한 사회적 관심을 높이는 계기가 될 것으로 기대된다.</p>
